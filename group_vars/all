---

# source code
# we don't use the SSH key anymore
# repository: git@github.com:dieterich-lab/gEAR.git 
repository: https://github.com/dieterich-lab/gEAR.git
# Branch or tag to deploy
git_version: DHART

# On initial install execute with "load_external_data": "yes"
# This implies "load_orthology_data": "yes"
load_external_data: no
load_orthology_data: no

# application user - owns the git project, app-related files, and python environment installation
app_user: www-data
app_group: www-data
app_directory: /dhart

gear_repo_dir: "{{ app_directory }}/gEAR"

# Defaults requirements gEAR v0.9.0 (master) are partly overridden
# Use system Python 3.13.5 to install virtual environment
# Debian GNU/Linux 13 (trixie) - 6.12.41+deb13-amd64

python_version: 3.13.5
python_dist_name:  "Python-{{ python_version }}"
python_venv_base: "/usr/local/envs"
python_venv_name: "{{ python_venv_base }}/dhart"

# gear.ini
db_name: dhart_db
db_user: dhart
mysql_port: 3306 

# DB dumps
# gene annotation - ensembl/genbank ftp.ensembl.org/ensembl/pub/release-{{ annotation_release }}/genbank/
annotation_release: 106
# Functional annotation
go_db: http://purl.obolibrary.org/obo/go.obo
# gene aliases - ftp.ncbi.nlm.nih.gov/gene/DATA/GENE_INFO

# these have to be as defined exactly as in create_schema.sql
organisms:
  - key: homo_sapiens
    value: 1
    taxa_id: 9606
  - key: mus_musculus
    value: 2
    taxa_id: 10090
  - key: rattus_norvegicus
    value: 3
    taxa_id: 10116
  - key: sus_scrofa
    value: 4
    taxa_id: 9823
  - key: danio_rerio
    value: 5
    taxa_id: 7955

r_setup_marker: "{{ app_directory }}/.r_setup_done"
r_home: /usr/local